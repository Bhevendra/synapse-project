					"from pyspark.sql.functions import *\n",
					"from pyspark.sql.types import *\n",
					"\n",
					"\n",
					"# Read source file dynamically\n",
					"df = spark.read.format(\"csv\") \\\n",
					"    .option(\"header\", \"true\") \\\n",
					"    .option(\"inferSchema\", \"true\") \\\n",
					"    .load(f\"abfss://{source_container}@ecomdevbranchstorage.dfs.core.windows.net/{bronze_table}\")\n",
					"\n",
					"# Add audit columns\n",
					"bronze_df = df \\\n",
					"    .withColumn(\"file_path\", input_file_name()) \\\n",
					"    .withColumn(\"last_update_ts\", current_timestamp())\n",
					"\n",
					"# Write to bronze dynamically\n",
					"bronze_df.write.format(\"delta\") \\\n",
					"    .mode(\"overwrite\") \\\n",
					"    .save(f\"abfss://{bronze_container}@ecomdevbranchstorage.dfs.core.windows.net/{bronze_table}/\")"
				],
				"execution_count": 6
			}
